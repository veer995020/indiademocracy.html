#!/bin/bash
# ================================================================
#  LINUX SYSTEM OPTIMIZER - MASTER v7.0 (BASH EDITION)
#  10 Steps | Elapsed Time | Safe Cleanup | Background Logging
#
#  HOW TO RUN:
#    sudo chmod +x optimizer.sh
#    sudo ./optimizer.sh
# ================================================================

# ── AUTO-ELEVATE CHECK ──────────────────────────────────────────
if [ "$EUID" -ne 0 ]; then
    echo -e "\033[0;31m[!] Error: Please run this script as root.\033[0m"
    echo -e "Try: \033[1msudo $0\033[0m"
    exit 1
fi

# ── FORMATTING & VARIABLES ──────────────────────────────────────
BOLD='\033[1m'
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DARK_GRAY='\033[1;30m'
NC='\033[0m' # No Color

LOG_FILE="/tmp/linux_optimizer_$(date +%s).log"
> "$LOG_FILE" # Initialize empty log

START_TIME=$(date +%s)

# ── UI HELPER FUNCTIONS ─────────────────────────────────────────
draw_header() {
    clear
    echo -e "${CYAN}================================================================${NC}"
    echo -e "${BOLD}${CYAN}               LINUX SYSTEM OPTIMIZER  ·  v7.0                  ${NC}"
    echo -e "${DARK_GRAY}       10-Step Pipeline · Live Logging · No User Files Deleted  ${NC}"
    echo -e "${CYAN}================================================================${NC}\n"
    echo -e "Detailed execution log saved to: ${BOLD}$LOG_FILE${NC}\n"
}

# Spinner function runs in the background while commands execute
run_step() {
    local step_num=$1
    local description=$2
    local cmd=$3

    # Print step description
    printf "${BLUE}[*] STEP %-2s / 10:${NC} %-35s " "$step_num" "$description"

    # Execute command in background, append all output to log
    eval "$cmd" >> "$LOG_FILE" 2>&1 &
    local pid=$!

    # Simple visual spinner while waiting for the background process
    local delay=0.1
    local spinstr='|/-\'
    while kill -0 $pid 2>/dev/null; do
        local temp=${spinstr#?}
        printf " [%c]  " "$spinstr"
        local spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b\b\b\b\b\b"
    done

    # Get exit status of the command
    wait $pid
    local status=$?

    # Print result
    if [ $status -eq 0 ]; then
        echo -e "${GREEN}[ DONE ]${NC}"
    else
        echo -e "${RED}[ FAIL ]${NC}"
        echo -e "    ${DARK_GRAY}-> Check log for details: tail -n 10 $LOG_FILE${NC}"
    fi
}

draw_header

# ── THE 10-STEP PIPELINE ────────────────────────────────────────

# 1. Windows Update -> apt update
run_step "1" "System Package Sync (Update)" \
    "apt-get update -y"

# 2. App Updates (winget) -> apt upgrade
run_step "2" "App & Core Upgrades" \
    "DEBIAN_FRONTEND=noninteractive apt-get upgrade -y"

# 3. DISM Image Repair -> apt --fix-broken & dpkg configure
run_step "3" "Dependency & Image Repair" \
    "dpkg --configure -a && apt-get --fix-broken install -y"

# 4. SFC System File Scan -> Package integrity check
run_step "4" "System File Scan (Integrity)" \
    "apt-get check"

# 5. Drive Optimization -> SSD TRIM
run_step "5" "Drive Optimization (TRIM)" \
    "fstrim -av"

# 6. Performance Tweaks -> Dropping PageCache, dentries, inodes
run_step "6" "Performance Tweaks (Drop Caches)" \
    "sync; echo 3 > /proc/sys/vm/drop_caches"

# 7. Privacy & Telemetry Kill -> Disable Ubuntu Apport/Pop-contest
run_step "7" "Privacy & Telemetry Kill" \
    "systemctl disable apport.service 2>/dev/null; apt-get remove popularity-contest -y 2>/dev/null || true"

# 8. Memory & CPU Tuning -> Swappiness adjustment (Prefer RAM over Swap)
run_step "8" "Memory & CPU Tuning" \
    "sysctl -w vm.swappiness=10 && sysctl -w vm.vfs_cache_pressure=50"

# 9. Network Optimization -> TCP Fast Open
run_step "9" "Network Optimization" \
    "sysctl -w net.ipv4.tcp_fastopen=3"

# 10. Startup + DNS + Cleanup -> DNS Flush & orphaned package removal
run_step "10" "Startup, DNS Flush & Cleanup" \
    "resolvectl flush-caches 2>/dev/null || systemd-resolve --flush-caches 2>/dev/null; apt-get autoremove -y && apt-get clean"

# ── FOOTER & TIME TRACKING ──────────────────────────────────────
END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))
MINS=$((ELAPSED / 60))
SECS=$((ELAPSED % 60))

echo ""
echo -e "${GREEN}================================================================${NC}"
echo -e "${BOLD}${GREEN} ✓ ALL 10 STEPS COMPLETE${NC}"
printf "${DARK_GRAY} Completed in %02d:%02d${NC}\n" $MINS $SECS
echo -e "${CYAN}================================================================${NC}"
echo -e "A system restart is recommended to fully apply kernel and network tuning."
echo -e "Type ${BOLD}sudo reboot${NC} to restart your machine now."
echo ""
